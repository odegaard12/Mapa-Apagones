# Mapa Apagones - ejemplo de variables de entorno
# Copia este archivo como .env solo en entornos locales/privados.
# No subas .env real al repositorio.

# Backend
DB_PATH=/data/app.db

# IGN/CNIG reverse geocoding
IGN_WFS_ENABLED=1
IGN_WFS_TIMEOUT=12
IGN_WFS_USER_AGENT=ApagonesCiudadanos/0.9

# Cloudflare Turnstile
# En local normalmente queda desactivado.
TURNSTILE_ENABLED=0
TURNSTILE_SECRET_KEY=

# Frontend / Cloudflare Pages
# En local puede quedar vacío porque Docker usa /api.
VITE_API_BASE_URL=
VITE_TURNSTILE_SITE_KEY=

# Producción futura sugerida:
# TURNSTILE_ENABLED=1
# TURNSTILE_SECRET_KEY=...
# VITE_API_BASE_URL=https://api.mapaapagones.es
# VITE_TURNSTILE_SITE_KEY=...
