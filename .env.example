# Mapa Apagones - ejemplo de variables de entorno
# No subas .env real al repositorio.

DB_PATH=/data/app.db

IGN_WFS_ENABLED=1
IGN_WFS_TIMEOUT=12
IGN_WFS_USER_AGENT=ApagonesCiudadanos/0.9

TURNSTILE_ENABLED=0
TURNSTILE_SECRET_KEY=

VITE_API_BASE_URL=
VITE_TURNSTILE_SITE_KEY=

# Producción futura:
# TURNSTILE_ENABLED=1
# TURNSTILE_SECRET_KEY=...
# VITE_API_BASE_URL=https://api.mapaapagones.es
# VITE_TURNSTILE_SITE_KEY=...

# CORS / debug
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8098,http://127.0.0.1:8098,http://192.168.68.103:8098,https://mapaapagones.es,https://www.mapaapagones.es
DEBUG_ENDPOINTS=0

# SQLite / backups
DB_PATH=/data/app.db
BACKUP_DIR=./backups/sqlite
KEEP_DAYS=14
