.git
.gitignore

# Python / backend caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Local data / secrets
.env
.env.*
!.env.example
data/
backups/
private_legal/
*.db
*.sqlite
*.sqlite3
*.log

# Frontend generated/vendor files
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Local accidental backups
*.bak
*.bak.*
*.tmp
*.swp
.DS_Store
